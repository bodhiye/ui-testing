{
  "name": "ui-testing",
  "description": "复用本地已登录 Chrome 会话的 UI 自动化测试工具：先分析页面并沉淀 path 级 playbook，再按优先级执行 E2E 用例并输出标准化报告。支持自我进化：组件库知识库、失败模式挖掘、置信度管理、历史趋势检测。",
  "version": "2.0.0",
  "entry": "SKILL.md",
  "triggers": [
    "ui 自动化测试",
    "UI 测试",
    "E2E 测试",
    "Playbook",
    "测试报告",
    "页面遍历",
    "更新用例",
    "查询 Playbook",
    "查询报错",
    "导出测试报告",
    "组件库交互",
    "进化日志",
    "知识库"
  ],
  "inputs": {
    "url": {
      "type": "string",
      "required": true,
      "description": "待测试的完整 http/https URL"
    },
    "updateCase": {
      "type": "boolean",
      "required": false,
      "default": false,
      "description": "是否更新用例；true 表示重新遍历并覆盖 Playbook"
    },
    "command": {
      "type": "string",
      "required": false,
      "description": "辅助指令，如 queryPlaybook、exportReport、stopTest、queryErrors、editCase、deleteCase、queryKnowledge、evolutionStatus"
    },
    "instruction": {
      "type": "string",
      "required": false,
      "description": "用户的自然语言补充要求"
    }
  },
  "outputs": {
    "status": "number",
    "message": "string",
    "data": "object"
  },
  "capabilities": [
    "url_validation",
    "site_bfs_traversal",
    "playbook_generation",
    "playbook_query",
    "playbook_editing",
    "e2e_execution",
    "error_aggregation",
    "markdown_report_generation",
    "component_lib_detection",
    "page_pattern_detection",
    "component_lib_knowledge",
    "failure_pattern_mining",
    "knowledge_confidence_management",
    "historical_trend_tracking",
    "flaky_test_detection",
    "regression_detection",
    "evolution_logging"
  ],
  "constraints": [
    "仅处理单个 URL",
    "仅适用于 Web UI 测试",
    "仅遍历待测域名内页面",
    "不执行恶意、破坏性或越权操作",
    "不持久化存储敏感凭据"
  ],
  "knowledgePaths": {
    "componentLib": "knowledge/component-lib.md",
    "evolutionLog": "knowledge/evolution-log.md"
  }
}
